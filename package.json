{
  "name": "vcard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "copy:assets": "cp -r content/**/*.{png,jpeg,jpg} public/assets",
    "copy:articles": "cp -r content .next/server/chunks",
    "build": "next build && yarn copy:articles && yarn copy:assets",
    "start": "next start"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/react-editor": "^3.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "next": "16.2.4",
    "node-fetch": "^3.3.2",
    "normalize.css": "^8.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rss-parser": "^3.13.0",
    "showdown": "^2.1.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
